    {
      "name": "📝 Snippets - User A",
      "item": [
        {
          "name": "Create Snippet (User A)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN_USER_A}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Función de suma\",\n  \"language\": \"javascript\",\n  \"code\": \"const sum = (a, b) => a + b;\",\n  \"tags\": [\"math\", \"basics\"],\n  \"description\": \"Función simple que suma dos números\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/snippets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "snippets"]
            }
          }
        },
        {
          "name": "List My Snippets (User A)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN_USER_A}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/snippets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "snippets"]
            }
          }
        },
        {
          "name": "Get Snippet by ID (User A)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN_USER_A}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/snippets/{{SNIPPET_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "snippets", "{{SNIPPET_ID}}"]
            }
          }
        },
        {
          "name": "Update Snippet (User A)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN_USER_A}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Función de suma mejorada\",\n  \"language\": \"javascript\",\n  \"code\": \"const sum = (a, b) => { console.log(a, b); return a + b; };\",\n  \"tags\": [\"math\", \"utilities\"]\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/snippets/{{SNIPPET_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "snippets", "{{SNIPPET_ID}}"]
            }
          }
        },
        {
          "name": "Delete Snippet (User A)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN_USER_A}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/api/v1/snippets/{{SNIPPET_ID}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "snippets", "{{SNIPPET_ID}}"]
            }
          }
        }
      ]
    },
